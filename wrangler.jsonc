{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "main": "./.output/server/index.mjs",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./.output/public/"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "khairin",
      "database_id": "e8d69866-78f1-48ea-b84c-a5b3782530cc"
    }
  ],
  "observability": {
    "enabled": true
  }
}
